# =============================================================================
# TrendsMix — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# =============================================================================

# Public site URL (used for canonical URLs, sitemap, Open Graph).
# On Vercel this is set automatically via VERCEL_URL; override only if you
# have a custom domain.
NEXT_PUBLIC_SITE_URL=https://trendsmix.com
