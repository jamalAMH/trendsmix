# =============================================================================
# TrendsMix — Environment Variables
# =============================================================================
#
# SETUP:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in the values below
#   3. Restart the dev server:  npm run dev
#
# =============================================================================

# ---------------------------------------------------------------------------
# Site URL  (optional for local dev, required for production)
# ---------------------------------------------------------------------------
# Used for canonical URLs, sitemap, Open Graph images.
# On Vercel, defaults to the deploy URL if not set.
NEXT_PUBLIC_SITE_URL=https://trendsmix.com

# ---------------------------------------------------------------------------
# Supabase  (required)
# ---------------------------------------------------------------------------
# Where to find these values:
#   Supabase Dashboard → Your Project → Settings → API
#
# "Project URL"  →  paste as NEXT_PUBLIC_SUPABASE_URL
# "anon public"  →  paste as NEXT_PUBLIC_SUPABASE_ANON_KEY
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
